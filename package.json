{
  "name": "wwlight.github.io",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@11.11.0",
  "scripts": {
    "dev": "astro dev",
    "dev:admin": "node scripts/dev-admin.mjs",
    "dev:all": "node scripts/dev-all.mjs",
    "build": "node scripts/generate-bookmark-logos.mjs && astro build",
    "generate:bookmark-logos": "node scripts/generate-bookmark-logos.mjs",
    "preview": "astro preview",
    "astro": "astro",
    "generate:color-themes": "node scripts/generate-color-theme-css.mjs",
    "generate:theme-init": "node scripts/generate-theme-init.mjs",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "lint-staged": "lint-staged",
    "prepare": "simple-git-hooks"
  },
  "dependencies": {
    "@astrojs/markdown-remark": "catalog:astro",
    "@astrojs/mdx": "catalog:astro",
    "@astrojs/react": "catalog:astro",
    "@astrojs/starlight": "catalog:astro",
    "@astrojs/starlight-tailwind": "catalog:astro",
    "@jsdevtools/rehype-url-inspector": "catalog:content",
    "@radix-ui/react-dialog": "catalog:frontend",
    "@radix-ui/react-dropdown-menu": "catalog:frontend",
    "@radix-ui/react-label": "catalog:frontend",
    "@radix-ui/react-popover": "catalog:frontend",
    "@radix-ui/react-select": "catalog:frontend",
    "@radix-ui/react-separator": "catalog:frontend",
    "@radix-ui/react-slot": "catalog:frontend",
    "@radix-ui/react-tabs": "catalog:frontend",
    "@radix-ui/react-tooltip": "catalog:frontend",
    "@tailwindcss/vite": "catalog:frontend",
    "astro": "catalog:astro",
    "astro-mermaid": "catalog:content",
    "class-variance-authority": "catalog:frontend",
    "clsx": "catalog:frontend",
    "lucide-react": "catalog:frontend",
    "mermaid": "catalog:content",
    "react": "catalog:frontend",
    "react-dom": "catalog:frontend",
    "sharp": "catalog:content",
    "sonner": "catalog:frontend",
    "tailwind-merge": "catalog:frontend",
    "tailwindcss": "catalog:frontend"
  },
  "devDependencies": {
    "@antfu/eslint-config": "catalog:devtools",
    "@types/react": "catalog:types",
    "@types/react-dom": "catalog:types",
    "eslint": "catalog:devtools",
    "eslint-plugin-astro": "catalog:devtools",
    "eslint-plugin-format": "catalog:devtools",
    "lint-staged": "catalog:devtools",
    "simple-git-hooks": "catalog:devtools",
    "vite": "catalog:build"
  },
  "simple-git-hooks": {
    "pre-commit": "node node_modules/lint-staged/bin/lint-staged.js"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,astro,mdx,json,css,md}": "eslint --fix"
  }
}
