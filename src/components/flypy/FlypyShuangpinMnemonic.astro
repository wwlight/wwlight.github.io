---
import {
  flypyShuangpinToneClass,
  flypySvgBoardClass,
  flypySvgBrandFoClass,
  flypySvgDownloadBtnClass,
  flypySvgKeyFill,
  flypySvgKeyStroke,
} from './flypy-classes'
import {
  buildMnemonicSvgLayout,
  FLYPY_SVG_RADIUS,
} from './flypy-shuangpin-svg-layout'
import FlypyFigure from './FlypyFigure.astro'

const layout = buildMnemonicSvgLayout()
---

<FlypyFigure ariaLabel="小鹤双拼键位口诀">
  <svg
    class={flypySvgBoardClass}
    viewBox={layout.viewBox}
    role="img"
    aria-label="小鹤双拼键位口诀"
  >
    <g data-part="keyboard">
      {
        layout.keys.map(key => (
          <g data-key={key.key}>
            <rect
              x={key.x}
              y={key.y}
              width={key.size}
              height={key.size}
              rx={FLYPY_SVG_RADIUS}
              ry={FLYPY_SVG_RADIUS}
              fill={flypySvgKeyFill}
              stroke={flypySvgKeyStroke}
              stroke-width="1"
            />
            <text
              x={key.letter.x}
              y={key.letter.y}
              font-size={key.letter.size}
              font-weight="700"
              text-anchor={key.letter.anchor}
              fill="currentColor"
              class={flypyShuangpinToneClass[key.letter.tone]}
            >
              {key.letter.text}
            </text>
            {key.topRight.map(item => (
              <text
                x={item.x}
                y={item.y}
                font-size={item.size}
                font-weight="500"
                text-anchor={item.anchor}
                fill="currentColor"
                class={flypyShuangpinToneClass[item.tone]}
              >
                {item.text}
              </text>
            ))}
            {key.finals.map(item => (
              <text
                x={item.x}
                y={item.y}
                font-size={item.size}
                font-weight="500"
                text-anchor={item.anchor}
                fill="currentColor"
                class={flypyShuangpinToneClass[item.tone]}
              >
                {item.text}
              </text>
            ))}
          </g>
        ))
      }

      <foreignObject
        x={layout.brand.x}
        y={layout.brand.y}
        width={layout.brand.size}
        height={layout.brand.size}
      >
        <div class={flypySvgBrandFoClass}>
          <button
            type="button"
            class={flypySvgDownloadBtnClass}
            data-flypy-svg-download
            data-download-name="小鹤双拼键位口诀.png"
            aria-label="下载小鹤双拼键位口诀 PNG"
            title="下载 PNG"
          >
            <span>小鹤<br />双拼</span>
          </button>
        </div>
      </foreignObject>
    </g>
  </svg>
</FlypyFigure>

<script>
  import { setupFlypySvgDownload } from './flypy-svg-download'

  setupFlypySvgDownload()
  document.addEventListener('astro:page-load', setupFlypySvgDownload)
</script>
