---
import {
  flypyBrandButtonClass,
  flypyBrandPreviewClass,
  flypyBrandPreviewImgClass,
  flypyBrandWrapClass,
} from './flypy-classes'

interface Props {
  previewSrc: string
  previewAlt: string
}

const { previewSrc, previewAlt } = Astro.props
---

<div class={flypyBrandWrapClass}>
  <button type="button" class={flypyBrandButtonClass} aria-label={`${previewAlt}，悬停查看原图`}>
    <span>小鹤<br />双拼</span>
  </button>
  <div class={flypyBrandPreviewClass} role="tooltip" aria-hidden="true">
    <img
      class={flypyBrandPreviewImgClass}
      src={previewSrc}
      alt={previewAlt}
      loading="lazy"
      decoding="async"
    />
  </div>
</div>
