---
import { Icon } from '@astrojs/starlight/components';
---

<script>
  import { syncStoredTheme, toggleThemeWithTransition } from '@/lib/theme'

  class ThemeSwitcher extends HTMLElement {
    constructor() {
      super()
      this.handleToggleTheme = this.handleToggleTheme.bind(this)
    }

    connectedCallback() {
      syncStoredTheme()
      this.addEventListener('click', this.handleToggleTheme)
    }

    disconnectedCallback() {
      this.removeEventListener('click', this.handleToggleTheme)
    }

    private handleToggleTheme(event: MouseEvent) {
      if (!event)
        return
      toggleThemeWithTransition(event)
    }
  }

  customElements.define('theme-switcher', ThemeSwitcher)
</script>

<theme-switcher
  class="flex items-center cursor-pointer p-2 rounded-full hover:bg-(--sl-color-gray-5) transition duration-300"
>
  <Icon
    name="sun"
    size="1.2rem"
    color="var(--sl-color-text-accent)"
    class="block dark:hidden"
  />
  <Icon
    name="moon"
    size="1.1rem"
    color="var(--sl-color-text-accent)"
    class="hidden dark:block"
  />
</theme-switcher>
