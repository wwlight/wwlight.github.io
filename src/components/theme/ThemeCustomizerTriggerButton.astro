---
import {
  themeCustomizerTriggerButtonClass,
  themeCustomizerTriggerLabelClass,
  themeCustomizerTriggerSwatchClass,
} from '@/lib/theme-customizer-trigger-styles'

interface Props {
  variant?: 'bookmarks' | 'starlight'
  class?: string
}

const { variant = 'bookmarks', class: className } = Astro.props
---

<button
  type="button"
  class={themeCustomizerTriggerButtonClass(variant, className)}
  aria-label="主题设置"
  aria-expanded="false"
  data-theme-customizer-trigger
>
  <span class={themeCustomizerTriggerSwatchClass(variant)} data-part="swatch" aria-hidden="true"></span>
  <span class={themeCustomizerTriggerLabelClass()} data-part="label"></span>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    width="14"
    height="14"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="2"
    stroke-linecap="round"
    stroke-linejoin="round"
    class="size-3.5 shrink-0 opacity-60"
    aria-hidden="true"
  >
    <path d="M20 7h-9"></path>
    <path d="M14 17H5"></path>
    <circle cx="17" cy="17" r="3"></circle>
    <circle cx="7" cy="7" r="3"></circle>
  </svg>
</button>
